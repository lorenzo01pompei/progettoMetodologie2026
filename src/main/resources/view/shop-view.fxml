<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.Pane?>
<VBox spacing="10" style="-fx-background-color: #fdf6e3; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125936.controller.ShopController">
    <Label style="-fx-font-weight: bold;" text="NEGOZIO">
        <font>
            <Font size="20" />
        </font>
    </Label>

    <VBox spacing="5">
        <TitledPane text="ARMI" expanded="false">
            <content>
                <VBox fx:id="weaponList" spacing="8" style="-fx-padding: 10;" />
            </content>
        </TitledPane>
        <TitledPane text="INCANTESIMI" expanded="false">
            <content>
                <VBox fx:id="spellList" spacing="8" style="-fx-padding: 10;" />
            </content>
        </TitledPane>
        <TitledPane text="STRUMENTI" expanded="false">
            <content>
                <VBox fx:id="toolList" spacing="8" style="-fx-padding: 10;" />
            </content>
        </TitledPane>
        <TitledPane text="VITE" expanded="false">
            <content>
                <VBox spacing="8" style=" -fx-padding: 10;">
                    <VBox fx:id="lifeList" spacing="8" style="-fx-padding: 10;" />
                    <VBox fx:id="hpRefill" spacing="8" style="-fx-padding: 10;" />
                </VBox>
            </content>
        </TitledPane>
    </VBox>

    <Label style="-fx-font-weight: bold;" text="VENDI">
            <font>
                <Font size="20" />
            </font>
    </Label>

    <VBox spacing="5">
        <Pane>
            <VBox fx:id="materialSell" spacing="8" style="-fx-padding: 10;" />
        </Pane>
    </VBox>

</VBox>
