<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="30" style="-fx-background-color: #2c3e50; -fx-padding: 40;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125936.controller.MenuController">

    <Label text="RPG Game" textFill="white">
        <font>
            <Font size="48" />
        </font>
    </Label>

    <Button fx:id="newGameBtn" onAction="#handleNewGame" prefWidth="250" prefHeight="50" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="Nuova Partita" />

    <Button fx:id="continueBtn" onAction="#handleContinue" prefWidth="250" prefHeight="50" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="Continua" />

</VBox>
