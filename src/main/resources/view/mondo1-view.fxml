<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768" prefWidth="1024" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125936.controller.Mondo1Controller">

    <top>
        <VBox spacing="5" style="-fx-padding: 15 20; -fx-background-color: #2c3e50;">
            <Label fx:id="titleLabel" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;" text="Mondo 1" />
            <HBox spacing="20">
                <Label fx:id="playerHpLabel" style="-fx-text-fill: #2ecc71; -fx-font-size: 14;" text="HP: 100" />
                <Label fx:id="playerLivesLabel" style="-fx-text-fill: #f1c40f; -fx-font-size: 14;" text="Vite: 3" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <VBox fx:id="enemyList" spacing="10" />
            <Label fx:id="feedbackLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 14;" text="" />
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 20;">
            <Button fx:id="backBtn" onAction="#handleBack" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 10 25;" text="Torna alla Lobby" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="mineBtn" onAction="#handleMine" style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 10 25;" text="Scava" />
        </HBox>
    </bottom>

</BorderPane>
