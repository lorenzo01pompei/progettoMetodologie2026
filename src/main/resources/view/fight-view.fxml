<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768" prefWidth="1024" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125936.controller.FightController">

    <top>
        <HBox spacing="30" style="-fx-padding: 20; -fx-background-color: #2c3e50;">
            <VBox spacing="5">
                <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="GIOCATORE" />
                <Label fx:id="playerNameLabel" style="-fx-text-fill: #2ecc71; -fx-font-size: 18;" text="Eroe" />
                <Label fx:id="playerHpLabel" style="-fx-text-fill: white; -fx-font-size: 14;" text="HP: 100" />
                <Label fx:id="playerLivesLabel" style="-fx-text-fill: #f1c40f; -fx-font-size: 14;" text="Vite: 3" />
            </VBox>
            <Label style="-fx-text-fill: #f1c40f; -fx-font-size: 28;" text="VS" />
            <VBox spacing="5">
                <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="NEMICO" />
                <Label fx:id="enemyNameLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 18;" text="Nemico" />
                <Label fx:id="enemyHpLabel" style="-fx-text-fill: white; -fx-font-size: 14;" text="HP: 100" />
            </VBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 30;">
            <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Scegli un'arma per attaccare:" />
            <VBox fx:id="weaponList" spacing="8" />
            <Separator />
            <Label fx:id="feedbackLabel" style="-fx-font-size: 14; -fx-text-fill: #2c3e50;" text="Pronto a combattere!" wrapText="true" />
            <Button fx:id="backButton" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 16; -fx-padding: 12 30;" text="Torna al Mondo" visible="false" managed="false" onAction="#goBack" />
        </VBox>
    </center>

</BorderPane>

